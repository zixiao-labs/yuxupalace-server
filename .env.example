# Copy this file to `.env` at the repo root and edit for your environment.
# `.env` is gitignored; never commit real secrets.
# yuxu-server loads it automatically on startup via dotenvy.

# --- Server bind address ---
# SocketAddr; defaults to 0.0.0.0:8080 if unset.
YUXU_BIND=0.0.0.0:8080

# --- Database ---
# sqlite (default build): file URL with mode=rwc to create on first run.
# postgres (build with --features postgres): libpq-style URL.
DATABASE_URL=sqlite://yuxu.db?mode=rwc
# DATABASE_URL=postgres://postgres:postgres@localhost/yuxu

# --- Deployment mode ---
# Either "self-hosted" or "saas". Defaults to "self-hosted" if unset.
#
# self-hosted:
#   - local username/password registration + login enabled
#   - GitHub OAuth enabled (when GITHUB_CLIENT_ID/SECRET configured)
#   - Zixiao Labs Cloud Account OAuth enabled (when ZIXIAO_CLOUD_* configured)
#
# saas:
#   - local username/password registration + login DISABLED (HTTP 403)
#   - GitHub OAuth enabled (when configured)
#   - Zixiao Labs Cloud Account OAuth enabled (when configured)
#   The bundled frontend at /login renders only the cloud-based providers
#   in this mode; it no longer depends on the uni-login frontend.
YUXU_DEPLOYMENT_MODE=self-hosted

# --- JWT ---
# REQUIRED in non-dev mode. Must be >=32 bytes. Generate with, for example:
#   openssl rand -base64 48
YUXU_JWT_SECRET=replace-me-with-a-32-plus-byte-random-secret-value

# Token lifetime in seconds; defaults to 86400 (24h).
YUXU_JWT_TTL_SECS=86400

# Set to 1 to auto-generate an ephemeral JWT secret for local dev.
# Tokens will not survive a restart. Leave unset in production.
# YUXU_DEV_MODE=1

# --- LiveKit (optional) ---
# Empty by default; set when collab audio/video is enabled.
YUXU_LIVEKIT_URL=

# --- GitHub OAuth (optional) ---
# Both must be set together to enable the GitHub provider.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Zixiao Labs Cloud Account OAuth (optional) ---
# Standard OAuth 2.0 authorization-code client credentials issued by the
# Zixiao Cloud Account service (uni-login). Required to enable the
# "紫霄实验室云账号" provider on the login page.
#
# ZIXIAO_CLOUD_BASE_URL is the public origin of the cloud account auth
# server (no trailing slash), e.g.
#   https://account.zixiao-labs.com         (production SaaS)
#   http://localhost:5173                   (uni-login dev frontend)
# The server expects standard endpoints under it:
#   {BASE}/oauth/authorize
#   {BASE}/oauth/token
#   {BASE}/oauth/userinfo
ZIXIAO_CLOUD_CLIENT_ID=
ZIXIAO_CLOUD_CLIENT_SECRET=
ZIXIAO_CLOUD_BASE_URL=

# --- CORS ---
# Comma-separated list, or "*" for any origin (dev only). Empty disables CORS.
# YUXU_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Logging ---
# tracing-subscriber EnvFilter; falls back to "yuxu_server=info,tower_http=info".
# RUST_LOG=yuxu_server=debug,tower_http=info
